---
import Header from "../../components/Header.astro"
import SearchBar from "../../components/SearchBar.astro"
import GlobeContainer from "../../components/GlobeContainer.astro"
import staticData from "./../all.json" assert { type: "json" };
import staticDataEurope from "./../europe.json" assert { type: "json" };
import staticDataAsia from "./../asia.json" assert { type: "json" };
import staticDataAfrica from "./../africa.json" assert { type: "json" };
import staticNAmerica from "./../northAmerica.json" assert { type: "json" };
import staticSAmerica from "./../southAmerica.json" assert { type: "json" };
import staticDataAus from "./../australia.json" assert { type: "json" };

let flightInfo = undefined;
const europeInfo = staticDataEurope;
const asiaInfo = staticDataAsia;
const africaInfo = staticDataAfrica;
const northAmericaInfo = staticNAmerica;
const southAmericaInfo = staticSAmerica;
const ausInfo = staticDataAus;
let onrender = import.meta.env.ONRENDER;

if (onrender)
{
	flightInfo = staticData;
}
else {
	const base = "https://opensky-network.org/api/states/all?";

	const aus = "lamin=-43.6&lomin=113.2&lamax=-10.7&lomax=153.6";
	const europe = "lamin=34.5&lomin=-31.3&lamax=71.2&lomax=40.0";
	const southAm = "lamin=-55.9&lomin=-81.3&lamax=12.5&lomax=-34.8";
	const northAm = "lamin=7.2&lomin=-168.0&lamax=83.6&lomax=-52.6";
	const afr = "lamin=-34.8&lomin=-17.5&lamax=37.3&lomax=51.4";
	const asia = "lamin=-10.0&lomin=26.0&lamax=77.7&lomax=180.0";

	const url = base + afr;
	const response = await fetch(url);
	flightInfo = await response.json();
}

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href="/global.css">
		<title>🛩</title>
	</head>
	<body>
		<Header />
		<SearchBar flightInfo={flightInfo}/>
		<GlobeContainer />
		<script src="https://cdn.jsdelivr.net/npm/globe.gl"></script>
		<script define:vars={{ flightInfo, europeInfo, asiaInfo, africaInfo, northAmericaInfo, southAmericaInfo, ausInfo}} type="module">
			// @ts-nocheck
			const globe = Globe()
			.height(900)
			.width(900)
			.globeImageUrl('./big.jpg')
			.backgroundColor('#141414');

			function updateGlobe(data) {
				const points = data.states
					.filter(s =>
						s[5] != null && s[6] != null &&
						!isNaN(Number(s[5])) && !isNaN(Number(s[6])) &&
						isFinite(Number(s[5])) && isFinite(Number(s[6]))
					)
					.map(state => ({
						lat: state[6],
						lng: state[5],
					}));
				globe
				.hexBinPointsData(points)
				.hexBinPointLat('lat')
				.hexBinPointLng('lng')
				.hexAltitude(({ sumWeight }) => sumWeight * 0.05)
				.hexTopColor(({ sumWeight }) => {
					if (sumWeight > 20) return 'rgb(9, 0, 255)';
					if (sumWeight > 10) return 'rgb(0, 255, 34)';
					if (sumWeight < 5)  return 'rgb(255, 0, 239)';
					return 'rgb(255, 0, 239)';
				})
				.hexSideColor(({ sumWeight }) => {
					if (sumWeight > 20) return 'rgba(9, 0, 255, 1)';
					if (sumWeight > 10) return 'rgba(0, 255, 34, 1)';
					if (sumWeight < 5)  return 'rgba(255, 0, 239, 1)';
					return 'rgb(255, 0, 239)';
				})
			}
			updateGlobe(flightInfo);
			document.getElementById('allBtn').addEventListener('click', () => updateGlobe(flightInfo));
			document.getElementById('asiaBtn').addEventListener('click', () => updateGlobe(asiaInfo));
			document.getElementById('europeBtn').addEventListener('click', () => updateGlobe(europeInfo));
			document.getElementById('africaBtn').addEventListener('click', () => updateGlobe(africaInfo));
			document.getElementById('nAmericaBtn').addEventListener('click', () => updateGlobe(northAmericaInfo));
			document.getElementById('sAmericaBtn').addEventListener('click', () => updateGlobe(southAmericaInfo));
			document.getElementById('ausBtn').addEventListener('click', () => updateGlobe(ausInfo));
			globe(document.getElementById('globeViz'));

			// Suppress known globe.gl internal NaN warning
			const _error = console.error.bind(console);
			console.error = (...args) => {
			if (typeof args[0] === 'string' && args[0].includes('computeBoundingSphere')) return;
			_error(...args);
			};
	</script>
	</body>
</html>
