---
import Card from "./Card.astro";
const {flightInfo} = Astro.props;

---

<section>
	<aside>
		<div id="search">
			<label for="search-bar">Search a flight
			</label>
			<input type="search" id="search-bar">
			<p class="filter-txt">Filters</p>
			<div class="filter-container">
				<div class="filters">
					<button id="allBtn">all</button>
					<button id="asiaBtn">Asia</button>
					<button id="europeBtn">Europe</button>
					<button id="africaBtn">Africa</button>
					<button>North America</button>
					<button>South America</button>
					<button>Australia</button>
				</div>
			</div>
		</div>
		<div id="flight-list">
			{ flightInfo.states.map(state => {
				const [route, place, title, pos, lastcontact, long, lat] = state;
				return (
				<div class="flight-card" data-title={title}>
					<Card title={title} place={place} route={route} longitude={long} latitude={lat} />
				</div>
				)
			})}
		</div>
	</aside>
</section>

<script>
  const searchBar = document.getElementById('search-bar') as HTMLInputElement;
  const flightList = document.getElementById('flight-list');

  function filterFlights() {
    const query = searchBar.value.toLowerCase().trim();
    const cards = flightList?.querySelectorAll('[data-title]');

    cards?.forEach(card => {
      const title = card.getAttribute('data-title')?.toLowerCase() ?? '';

      const matches = title.includes(query);
      (card as HTMLElement).style.display = matches ? '' : 'none';
    });
  }
  searchBar?.addEventListener('input', filterFlights);
  searchBar?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') filterFlights();
  });
</script>

<style>
	aside {
		outline: 1px solid var(--lines);
		width: 100%;
		overflow: scroll;
		height: 100vh;
		position: absolute;
		left: 50px;
	}

	section {
		outline: 1px solid var(--lines);
		position: relative;
	}

	label {
		padding: 30px 25px 20px 25px;
	}

	input {
		width: 275px;
		padding: 10px;
		margin: 0 25px;
		background: transparent;
		border: none;
		outline: 1px solid var(--lines);
		color: white;
	}

	button {
		color: white;
		background: black;
		outline: 1px solid var(--lines);
		border: none;
		padding: 10px;
		/* width: 100px; */
		margin: 10px 10px 0 0;
	}

	button:hover {
		cursor: pointer;
		background: white;
		color: black;
	}

	#search {
		display: flex;
		flex-direction: column;
		background-color: var(--bg-clr);
		border-bottom: 1px solid var(--lines);
	}

	#flight-list
	{
		padding: 10px 0;
	}

	.filter-container {
		overflow-y: scroll;
	}

	.filters {
		margin: 10px 25px;
		width: 800px;
	}

	.filter-txt {
		margin: 25px 5px 0 25px;
	}

	@media (min-width: 800px) {
		aside {
			width: 30%;
		}
	}
</style>