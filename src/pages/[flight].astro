---
<link rel="stylesheet" href="/global.css">

<section>
	<h2>Origin country {flightState[2]}</h2>
	<h1>Flight {flight}</h1>
	<ul>
		<li>icao24 {flightState[0]}</li>
		<li>callsign {flightState[1]}</li>
		<li>time position {flightState[3]}</li>
		<li>last contact {flightState[4]}</li>
		<li>longitude {flightState[5]}</li>
		<li>latitude {flightState[6]}</li>
		<li>baro altitude {flightState[7]}</li>
		<li>on ground {flightState[8]}</li>
		<li>velocity {flightState[9]}</li>
		<li>true track {flightState[10]}</li>
		<li>vertical rate {flightState[11]}</li>
		<li>sensors {flightState[12]}</li>
		<li>geo altitude {flightState[13]}</li>
		<li>squawk {flightState[14]}</li>
		<li>spi {flightState[15]}</li>
		<li>position source {flightState[16]}</li>
		<li>category {flightState[17]}</li>
